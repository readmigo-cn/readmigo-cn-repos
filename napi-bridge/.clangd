# clangd 配置 — 让 IDE / clangd 在没有 HarmonyOS SDK 的宿主上正确解析 napi-bridge/src/
#
# 实际编译时（DevEco Studio + HarmonyOS NDK），构建系统会提供真实的
# `napi/native_api.h`（位于 `${HARMONYOS_SDK}/native/sysroot/usr/include/napi/`）。
# 真实头文件优先级高于本目录的 stubs（因为 NDK 路径会通过 `-isystem` 注入到
# `compile_commands.json`，比 `-I` 优先级高）。
#
# 本配置只解决 IDE 红下划线问题，不影响生产构建。

CompileFlags:
  Add:
    # 优先寻找本地 stub
    - -I${ConfigDir}/stubs
    # C++ 17 标准（与 CMakeLists.txt 一致）
    - -std=c++17
    # 标记为宿主开发，便于源码 #ifdef 区分
    - -DREADMIGO_HOST_BUILD
  # 忽略 HarmonyOS NDK 才能提供的几个非关键 warning
  Remove:
    - -W*

Diagnostics:
  Suppress:
    # 即使有 stub，HarmonyOS 特定头（如 `<rawfile/raw_file.h>` 等）仍可能找不到
    # 在 napi-bridge 范围内统一忽略，避免噪声
    - 'pp_file_not_found'

Index:
  Background: Build
