    { "from": "main/ets/components/SsmlBuilder", "to": "main/ets/features/audiobook/components/SsmlBuilder" },
    { "from": "main/ets/components/VocabDetailSheet", "to": "main/ets/features/vocab/components/VocabDetailSheet" },
