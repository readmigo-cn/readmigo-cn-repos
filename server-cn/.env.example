# App
NODE_ENV=development
PORT=3001

# LLM
LLM_PRIMARY_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Huawei Cloud
HUAWEICLOUD_REGION=cn-east-3
HUAWEICLOUD_PROJECT_ID=
HUAWEICLOUD_ACCESS_KEY_ID=
HUAWEICLOUD_SECRET_ACCESS_KEY=
GAUSSDB_URL=
OBS_BUCKET=
OBS_ENDPOINT=
REDIS_URL=

# AppGallery Connect
AGC_APP_ID=
AGC_CLIENT_ID=
AGC_CLIENT_SECRET=
AGC_PROJECT_ID=

# Analytics / feature flags
AGC_ANALYTICS_ENABLED=true
AGC_REMOTE_CONFIG_ENABLED=true

# Repository / CI
GITEE_ORG=
GITEE_REPO=
GITEE_TOKEN=
