# Readmigo CN Backend - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ============================================
# Database (Huawei GaussDB or PostgreSQL)
# 本地 docker-compose: postgresql://readmigo:readmigo@localhost:5432/readmigo_cn
# 生产 GaussDB(for PostgreSQL): 在华为云控制台拿连接串
# ============================================
DATABASE_URL=postgresql://readmigo:readmigo@localhost:5432/readmigo_cn
DATABASE_SSL=false

# ============================================
# Redis (Caching & Sessions)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=dev-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# LLM Providers (Domestic China)
# ============================================

# DeepSeek (深度求索) - Primary for word explanations
DEEPSEEK_API_KEY=sk_xxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Qwen (阿里云通义千问) - Best for Chinese translation
QWEN_API_KEY=dashscope_xxxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-plus

# Zhipu (智谱 AI / GLM) - Backup provider
ZHIPU_API_KEY=xxxxxxxxxxxxx
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_DEFAULT_MODEL=glm-4

# Wenxin (百度文心一言) - Alternative for Chinese content
WENXIN_API_KEY=xxxxxxxxxxxxx
WENXIN_SECRET_KEY=xxxxxxxxxxxxx
WENXIN_DEFAULT_MODEL=ernie-bot-4

# ============================================
# TTS Providers (Domestic)
# ============================================

# iFlytek (讯飞) - Primary TTS
IFLYTEK_API_KEY=xxxxxxxxxxxxx
IFLYTEK_API_SECRET=xxxxxxxxxxxxx

# Aliyun TTS - Backup
ALIYUN_TTS_API_KEY=xxxxxxxxxxxxx

# ============================================
# Huawei Cloud Services
# ============================================

# OBS (Object Storage Service) - For avatars, book covers
HUAWEI_OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
HUAWEI_OBS_ACCESS_KEY=xxxxxxxxxxxxx
HUAWEI_OBS_SECRET_KEY=xxxxxxxxxxxxx
HUAWEI_OBS_BUCKET=readmigo-cn-assets

# GaussDB
HUAWEI_GAUSSDB_HOST=gauassdb.cn-north-4.myhuaweicloud.com
HUAWEI_GAUSSDB_PORT=5432
HUAWEI_GAUSSDB_DATABASE=readmigo_cn

# ============================================
# HMS (Huawei Mobile Services)
# ============================================

# Account Kit
HMS_CLIENT_ID=xxxxxxxxxxxxx
HMS_CLIENT_SECRET=xxxxxxxxxxxxx

# Push Kit
HMS_PUSH_APP_ID=xxxxxxxxxxxxx
HMS_PUSH_APP_SECRET=xxxxxxxxxxxxx

# IAP (In-App Purchase)
HMS_IAPP_PUBLIC_KEY=xxxxxxxxxxxxx

# ============================================
# Analytics & Monitoring
# ============================================

# Sentry (Error tracking)
SENTRY_DSN=https://xxxxxxxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxx

# Shence Data (神策数据) - Domestic analytics
SHENCE_API_URL=https://xxxxxxxxxxxxx.data.shen策.com
SHENCE_APP_ID=xxxxxxxxxxxxx

# ============================================
# Content Moderation (Domestic)
# ============================================

# Baidu AI Content Moderation (百度 AI 内容审核)
BAIDU_CONTENT_MOD_API_KEY=xxxxxxxxxxxxx
BAIDU_CONTENT_MOD_SECRET_KEY=xxxxxxxxxxxxx

# ============================================
# SMS Providers (For phone authentication)
# ============================================

# Alibaba Cloud SMS
ALIYUN_SMS_ACCESS_KEY=xxxxxxxxxxxxx
ALIYUN_SMS_ACCESS_SECRET=xxxxxxxxxxxxx
ALIYUN_SMS_SIGN_NAME=阅可

# Tencent Cloud SMS (Backup)
TENCENT_SMS_SECRET_ID=xxxxxxxxxxxxx
TENCENT_SMS_SECRET_KEY=xxxxxxxxxxxxx
TENCENT_SMS_APP_ID=xxxxxxxxxxxxx

# ============================================
# Email (For notifications)
# ============================================

# Huawei Cloud SES or Alibaba Cloud DirectMail
SMTP_HOST=smtp.cn-north-4.myhuaweicloud.com
SMTP_PORT=587
SMTP_USER=noreply@readmigo.cn
SMTP_PASSWORD=xxxxxxxxxxxxx
EMAIL_FROM=阅可 <noreply@readmigo.cn>

# ============================================
# Compliance & Legal
# ============================================

# ICP License Number (filled after approval)
ICP_LICENSE_NUMBER=京 ICP 备 XXXXXXXX 号

# Company Info
COMPANY_NAME=北京阅可科技有限公司
COMPANY_ADDRESS=北京市海淀区 xxx 路 xxx 号
